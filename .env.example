# MBA T-Shirt Factory Configuration
# Copy this file to .env and fill in your values

# App Settings
DEBUG=false
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32

# Shared bearer token guarding the API and the MCP bridge.
# Generate with:  openssl rand -hex 32
API_TOKEN=

# Public URL of the MCP bridge (used for OAuth discovery metadata)
MCP_PUBLIC_URL=https://mcp.mba.ooopppmmm.com

# ─── T-Shirt Factory (prefix TSF_) ───────────────────────────────
# Claude API for AI-powered analysis & prompt generation
TSF_ANTHROPIC_API_KEY=
TSF_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Marketplace & research cadence
TSF_AMAZON_MARKETPLACE=com
TSF_RESEARCH_INTERVAL_HOURS=24
TSF_MBA_TIER=100
